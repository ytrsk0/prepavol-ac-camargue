rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: fleet
    // Document ID: {planeId} (e.g., FBUPS)
    // Fields:
    //   - planetype: string (required) - Model of the aircraft
    //   - bew: number (required) - Basic Empty Weight
    //   - mtow: number (required) - Max Takeoff Weight
    //   - fuelrate: number (optional) - Fuel consumption rate
    //   - maxmainfuel: number (optional) - Main tank capacity
    //   - maxwingfuel: number (optional) - Wing tank capacity
    //   - maxauxfuel: number (optional) - Auxiliary tank capacity
    //   - unusable_mainfuel: number (optional)
    //   - unusable_wingfuel: number (optional)
    //   - bagmax: number (optional)
    //   - bagmax2: number (optional)
    //   - sumbagmax: number (optional)
    //   - arms: map (required) - Lever arms for all components
    //   - envelope: list (required) - CG envelope points as [[cg, weight], ...]
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "yannick.teresiak@gmail.com" && request.auth.token.email_verified == true);
    }

    // Domain Validators
    function isValidPlane(data) {
      return data.planetype is string && data.planetype.size() < 50 &&
             data.bew is number && data.bew > 0 &&
             data.mtow is number && data.mtow > 0 &&
             data.arms is map &&
             data.envelope is list && data.envelope.size() >= 3 &&
             data.takeoffRollGrid is list &&
             data.takeoff50ftGrid is list &&
             data.landingRollGrid is list &&
             data.landing50ftGrid is list;
    }

    // Rules
    match /fleet/{planeId} {
      // Fleet specifications are non-sensitive and public for all pilots
      allow read: if true;
      
      // Only admins can modify the fleet
      allow create: if isAdmin() && isValidPlane(request.resource.data);
      allow update: if isAdmin() && isValidPlane(request.resource.data);
      allow delete: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
